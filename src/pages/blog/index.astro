---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog" description="Einblicke in meinen künstlerischen Prozess — Ölmalerei, Technik und Inspiration aus Lübeck">
  <section class="pt-32 pb-24 md:pt-40 md:pb-40 max-w-[1000px] mx-auto px-6 md:px-10">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-light tracking-tighter mb-4" data-reveal>
      Blog
    </h1>
    <p class="text-lg text-[--color-text-muted] max-w-[55ch] leading-relaxed mb-16 md:mb-24" data-reveal>
      Gedanken, Einblicke und Geschichten rund um meine Arbeit als Künstler in Lübeck.
    </p>

    {posts.length === 0 ? (
      <p class="text-[--color-text-muted]" data-reveal>Noch keine Beiträge vorhanden.</p>
    ) : (
      <div class="space-y-16">
        {posts.map((post) => (
          <article class="border-t border-[--color-border] pt-8" data-reveal>
            <a href={`/blog/${post.id}`} class="group block">
              {(post.data.cardImage ?? post.data.heroImage) && (
                <div class="overflow-hidden mb-6 aspect-square max-w-[360px]">
                  <img
                    src={post.data.cardImage ?? post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.02]"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
              <time class="text-xs tracking-widest uppercase text-[--color-text-muted]">
                {post.data.pubDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="font-[Cormorant_Garamond] text-2xl md:text-3xl font-light tracking-tight mt-2 mb-3 group-hover:opacity-70 transition-opacity duration-300">
                {post.data.title}
              </h2>
              <p class="text-sm text-[--color-text-muted] leading-relaxed max-w-[55ch]">
                {post.data.description}
              </p>
            </a>
            {post.data.tags.length > 0 && (
              <div class="flex gap-3 mt-4 flex-wrap">
                {post.data.tags.map((tag: string) => (
                  <span class="text-xs tracking-wide text-[--color-text-muted] border border-[--color-border] px-3 py-1">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
