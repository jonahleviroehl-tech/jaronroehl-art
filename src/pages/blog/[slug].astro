---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const breadcrumbs = [
  { name: 'Startseite', url: 'https://jaronroehl-art.de/' },
  { name: 'Blog', url: 'https://jaronroehl-art.de/blog' },
  { name: post.data.title, url: `https://jaronroehl-art.de/blog/${post.id}` },
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.pubDate.toISOString(),
      ...(post.data.updatedDate && { "dateModified": post.data.updatedDate.toISOString() }),
      "author": {
        "@type": "Person",
        "name": "Jaron Röhl",
        "url": "https://jaronroehl-art.de"
      },
      "publisher": {
        "@type": "Person",
        "name": "Jaron Röhl"
      },
      ...(post.data.heroImage && { "image": `https://jaronroehl-art.de${post.data.heroImage}` }),
      "url": `https://jaronroehl-art.de/blog/${post.id}`
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbs.map((crumb, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": crumb.name,
        "item": crumb.url
      }))
    })} />
  </Fragment>

  <article class="pt-32 pb-24 md:pt-40 md:pb-40 max-w-[700px] mx-auto px-6 md:px-10">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-[--color-text-muted]" aria-label="Breadcrumb" data-reveal>
      <a href="/blog" class="hover:text-[--color-text] transition-colors duration-300">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-[--color-text]">{post.data.title}</span>
    </nav>

    <!-- Header -->
    <header data-reveal>
      <time class="text-xs tracking-widest uppercase text-[--color-text-muted]">
        {post.data.pubDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="text-3xl md:text-5xl lg:text-6xl font-light tracking-tighter mt-3 mb-8">
        {post.data.title}
      </h1>
    </header>

    <!-- Hero Image -->
    {post.data.heroImage && (
      <div class="mb-12" data-reveal>
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          class="w-full h-auto"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    <!-- Content -->
    <div class="prose" data-reveal>
      <Content />
    </div>

    <!-- Tags -->
    {post.data.tags.length > 0 && (
      <div class="flex gap-3 mt-12 flex-wrap border-t border-[--color-border] pt-8" data-reveal>
        {post.data.tags.map((tag: string) => (
          <span class="text-xs tracking-wide text-[--color-text-muted] border border-[--color-border] px-3 py-1">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Back -->
    <div class="mt-12" data-reveal>
      <a
        href="/blog"
        class="inline-block text-sm tracking-wide border border-[--color-border] px-6 py-3 hover:border-[--color-text] transition-all duration-300 text-[--color-text-muted] hover:text-[--color-text]"
      >
        Zurück zum Blog
      </a>
    </div>
  </article>
</BaseLayout>
