---
import BaseLayout from '../layouts/BaseLayout.astro';
import artworks from '../data/artworks.json';

// Always show both categories — Zeichnungen will populate as artworks are added
const allCategories = ['Ölgemälde', 'Zeichnungen', 'Aquarell'];
---

<BaseLayout title="Galerie" description="Digitales Kunstportfolio — Ölmalerei, Portraits und Zeichnungen von Jaron Röhl">
  <!-- Page Header -->
  <section class="pt-32 pb-8 md:pt-40 md:pb-12 max-w-[1400px] mx-auto px-6 md:px-10">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-light tracking-tighter" data-reveal>
      Galerie
    </h1>

    <div class="mt-8 flex gap-6 flex-wrap" data-reveal>
      <button
        class="category-btn active text-sm tracking-wide pb-1 border-b border-[--color-text] text-[--color-text] transition-all duration-300"
        data-filter="all"
      >
        Alle
      </button>
      {allCategories.map((cat) => (
        <button
          class="category-btn text-sm tracking-wide pb-1 border-b border-transparent text-[--color-text-muted] hover:text-[--color-text] transition-all duration-300"
          data-filter={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </section>

  <!-- Gallery Grid — columns masonry-style, auto-fills for any number of artworks -->
  <section class="max-w-[1400px] mx-auto px-6 md:px-10 pb-24 md:pb-40 mt-8 md:mt-12">
    <div
      class="columns-1 sm:columns-2 lg:columns-3 gap-6 md:gap-8 [column-fill:_balance]"
      id="gallery-grid"
    >
      {artworks.map((artwork) => (
        <div
          class="artwork-card group cursor-pointer break-inside-avoid mb-6 md:mb-8"
          data-artwork-id={artwork.id}
          data-category={artwork.category}
          role="button"
          tabindex="0"
          data-reveal
        >
          <div class="overflow-hidden">
            <img
              src={`/images/${artwork.folder}/${artwork.images[0]}`}
              alt={`${artwork.title} — ${artwork.medium}${artwork.dimensions ? `, ${artwork.dimensions}` : ''} von Jaron Röhl`}
              class="artwork-thumb w-full h-auto object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
              loading="lazy"
              decoding="async"
            />
          </div>
          {artwork.title && (
            <p class="mt-3 text-sm font-[Cormorant_Garamond] text-[--color-text] tracking-wide">
              {artwork.title}
            </p>
          )}
          <p class="mt-1 text-xs text-[--color-text-muted] tracking-wide">
            {artwork.medium}{artwork.dimensions ? ` — ${artwork.dimensions}` : ''}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- Artwork Detail Overlay -->
  <div class="artwork-overlay" id="artwork-overlay">
    <button
      id="overlay-close"
      class="fixed top-6 right-6 z-[60] w-11 h-11 flex items-center justify-center opacity-60 hover:opacity-100 transition-opacity duration-300"
      aria-label="Schließen"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="px-6 py-24" data-overlay-backdrop>
      <div class="max-w-[1000px] mx-auto" data-overlay-content>
        <!-- Main image (large) -->
        <div id="overlay-main-image"></div>

        <!-- Detail images (small, side by side) -->
        <div id="overlay-detail-images" class="grid grid-cols-3 sm:grid-cols-4 gap-3 mt-4"></div>

        <!-- Info + Buy -->
        <div class="mt-8 flex flex-col md:flex-row md:items-baseline md:justify-between gap-4 border-t border-[--color-border] pt-6">
          <p id="overlay-meta" class="text-sm text-[--color-text-muted]"></p>
          <a
            id="overlay-buy"
            href="/contact"
            class="inline-block text-sm tracking-wide border border-[--color-text] px-6 py-3 hover:bg-[--color-text] hover:text-[--color-bg] transition-all duration-300 active:scale-[0.98] self-start"
          >
            Werk anfragen
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { gsap } from 'gsap';
    import artworks from '../data/artworks.json';

    function initGallery() {
      const overlay = document.getElementById('artwork-overlay');
      const overlayMainImage = document.getElementById('overlay-main-image');
      const overlayDetailImages = document.getElementById('overlay-detail-images');
      const overlayMeta = document.getElementById('overlay-meta');
      const overlayBuy = document.getElementById('overlay-buy') as HTMLAnchorElement;
      const closeBtn = document.getElementById('overlay-close');

      if (!overlay || !overlayMainImage || !overlayDetailImages || !overlayMeta || !overlayBuy || !closeBtn) return;

      // Category filtering
      const filterBtns = document.querySelectorAll('.category-btn');
      const cards = document.querySelectorAll('.artwork-card');

      filterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const filter = btn.getAttribute('data-filter');

          filterBtns.forEach((b) => {
            b.classList.remove('active', 'border-[--color-text]', 'text-[--color-text]');
            b.classList.add('border-transparent', 'text-[--color-text-muted]');
          });
          btn.classList.add('active', 'border-[--color-text]', 'text-[--color-text]');
          btn.classList.remove('border-transparent', 'text-[--color-text-muted]');

          cards.forEach((card) => {
            const category = card.getAttribute('data-category');
            if (filter === 'all' || category === filter) {
              (card as HTMLElement).style.display = '';
              gsap.fromTo(card, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' });
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });
        });
      });

      // Detail overlay
      const openArtwork = (card: Element) => {
        const id = card.getAttribute('data-artwork-id');
        const artwork = artworks.find((a) => a.id === id);
        if (!artwork) return;

        // Main image (first image, displayed large)
        const altText = `${artwork.title} — ${artwork.medium}${artwork.dimensions ? ', ' + artwork.dimensions : ''} von Jaron Röhl`;
        overlayMainImage.innerHTML = `<img src="/images/${artwork.folder}/${artwork.images[0]}" alt="${altText}" class="overlay-img w-full h-auto" loading="eager" decoding="async" />`;

        // Detail images (remaining images, displayed small in a grid)
        if (artwork.images.length > 1) {
          overlayDetailImages.innerHTML = artwork.images
            .slice(1)
            .map(
              (img) =>
                `<img src="/images/${artwork.folder}/${img}" alt="${altText} — Detailansicht" class="overlay-img w-full h-auto object-cover aspect-square cursor-pointer hover:opacity-80 transition-opacity duration-300" loading="lazy" decoding="async" data-full-src="/images/${artwork.folder}/${img}" />`
            )
            .join('');
          overlayDetailImages.style.display = '';

          // Click detail thumbnail to swap with main image
          overlayDetailImages.querySelectorAll('img').forEach((thumb) => {
            thumb.addEventListener('click', () => {
              const mainImg = overlayMainImage.querySelector('img');
              if (!mainImg) return;
              const currentMain = mainImg.src;
              const newSrc = thumb.getAttribute('data-full-src') || thumb.src;
              mainImg.src = newSrc;
              thumb.src = currentMain;
              thumb.setAttribute('data-full-src', currentMain);
              gsap.fromTo(mainImg, { opacity: 0.5 }, { opacity: 1, duration: 0.3, ease: 'power2.out' });
            });
          });
        } else {
          overlayDetailImages.innerHTML = '';
          overlayDetailImages.style.display = 'none';
        }

        // Meta info
        const parts = [artwork.title, artwork.medium, artwork.dimensions, artwork.year].filter(Boolean);
        overlayMeta.textContent = parts.join(' — ');
        overlayBuy.href = `/contact?artwork=${artwork.id}`;

        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';

        // Animate in
        const allImgs = overlay.querySelectorAll('.overlay-img');
        gsap.fromTo(
          allImgs,
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out', stagger: 0.06, delay: 0.1 }
        );
      };

      cards.forEach((card) => {
        card.addEventListener('click', () => openArtwork(card));
        card.addEventListener('keydown', (e) => {
          if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
            e.preventDefault();
            openArtwork(card);
          }
        });
      });

      const closeOverlay = () => {
        const allImgs = overlay.querySelectorAll('.overlay-img');
        gsap.to(allImgs, {
          opacity: 0,
          duration: 0.25,
          ease: 'power2.in',
          onComplete: () => {
            overlay.classList.remove('active');
            document.body.style.overflow = '';
            overlay.scrollTop = 0;
          },
        });
      };

      closeBtn.addEventListener('click', closeOverlay);

      overlay.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (!target.closest('[data-overlay-content]') && !target.closest('#overlay-close')) {
          closeOverlay();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.classList.contains('active')) {
          closeOverlay();
        }
      });
    }

    initGallery();
    document.addEventListener('astro:after-swap', initGallery);
  </script>
</BaseLayout>
