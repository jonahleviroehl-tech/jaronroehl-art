---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Über mich" description="Jaron Röhl — Junger Künstler aus Lübeck, spezialisiert auf Ölmalerei, Portraits und Zeichnungen">
  <section class="pt-32 pb-24 md:pt-40 md:pb-40 max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">
      <!-- Text (left, wider) -->
      <div class="md:col-span-7 lg:col-span-6">
        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-light tracking-tighter mb-12"
          data-reveal
        >
          Über mich
        </h1>

        <div class="space-y-6 text-[--color-text] leading-relaxed" data-reveal>
          <p>
            Ich bin Jaron Röhl, ein junger Künstler aus Lübeck mit einer großen
            Leidenschaft für Kunst und visuelle Gestaltung. Seit mehreren Jahren
            arbeite ich in verschiedenen künstlerischen Bereichen wie Ölmalerei,
            Portraits, Zeichnung und Fotografie.
          </p>

          <p>
            Im Mittelpunkt meiner Arbeit stehen vor allem Ölbilder, in denen ich
            meinen eigenen Stil stetig weiterentwickle. Auf dieser Website
            präsentiere ich meine Werke, zeige meinen Fortschritt und mache
            meine Arbeiten für Sie zugänglich.
          </p>

          <p>
            Meine Bilder sind käuflich – bei Interesse oder Fragen können Sie
            mich jederzeit kontaktieren.
          </p>

          <p>
            Neben freien Arbeiten habe ich bereits Projekte im Bereich
            Gestaltung und Illustration umgesetzt, darunter Logos für Stiftungen
            sowie verschiedene Auftragsarbeiten. Ich bin offen für neue Ideen
            und kreative Projekte – sowohl im Bereich der Malerei als auch für
            illustrative Arbeiten.
          </p>
        </div>

        <div class="mt-12 flex flex-col sm:flex-row gap-4" data-reveal>
          <a
            href="/gallery"
            class="inline-block text-sm tracking-wide border border-[--color-text] px-6 py-3 hover:bg-[--color-text] hover:text-[--color-bg] transition-all duration-300 text-center"
          >
            Zur Galerie
          </a>
          <a
            href="https://www.instagram.com/jari_art_/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 text-sm tracking-wide border border-[--color-border] px-6 py-3 hover:border-[--color-text] transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            Instagram
          </a>
        </div>
      </div>

      <!-- Portrait Placeholder (right) -->
      <div class="md:col-span-5 lg:col-span-5 lg:col-start-8" data-reveal>
        <div class="aspect-[3/4] bg-[--color-bg-section] flex items-center justify-center">
          <p class="text-sm text-[--color-text-muted] italic">Portraitfoto folgt</p>
        </div>
      </div>
    </div>

    <!-- Bereiche -->
    <div class="mt-24 md:mt-40 border-t border-[--color-border] pt-16">
      <h2 class="text-2xl md:text-3xl font-light mb-12" data-reveal>Bereiche</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { title: 'Ölmalerei', desc: 'Hauptfokus meiner künstlerischen Arbeit in meinem Atelier in Lübeck' },
          { title: 'Portraits', desc: 'Charakterstudien in Öl und Zeichnung — auch als Auftragsarbeit' },
          { title: 'Zeichnungen', desc: 'Skizzen, Studien und freie Arbeiten auf Papier' },
          { title: 'Fotografie', desc: 'Dokumentation und künstlerische Fotografie in Norddeutschland' },
        ].map((area) => (
          <div class="border-t border-[--color-border] pt-6" data-reveal>
            <h3 class="font-[Cormorant_Garamond] text-xl font-light mb-2">{area.title}</h3>
            <p class="text-sm text-[--color-text-muted]">{area.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
