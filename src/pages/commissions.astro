---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kommissionen" description="Auftragsarbeiten von Jaron Röhl — Portraits, Gemälde, Zeichnungen und individuelle Projekte">
  <section class="pt-32 pb-24 md:pt-40 md:pb-40 max-w-[1000px] mx-auto px-6 md:px-10">
    <h1
      class="text-4xl md:text-6xl lg:text-7xl font-light tracking-tighter mb-8"
      data-reveal
    >
      Kommissionen
    </h1>
    <p class="text-lg text-[--color-text-muted] max-w-[55ch] leading-relaxed mb-16 md:mb-24" data-reveal>
      Ich nehme Auftragsarbeiten an — von Portraits über Gemälde bis hin zu
      individuellen Projekten. Jede Arbeit entsteht in persönlicher Absprache.
    </p>

    <!-- What I offer -->
    <div class="space-y-12 mb-20 md:mb-32">
      <h2 class="text-2xl md:text-3xl font-light" data-reveal>Was ich anbiete</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-8">
        {[
          { title: 'Portraits', desc: 'Individuelle Portraitmalerei in Öl — nach Fotovorlage oder live.' },
          { title: 'Gemälde', desc: 'Freie und thematische Ölmalerei in verschiedenen Formaten.' },
          { title: 'Zeichnungen', desc: 'Detaillierte Zeichnungen und Studien auf Papier.' },
          { title: 'Individuelle Projekte', desc: 'Logos, Illustrationen und kreative Konzepte nach Ihren Vorstellungen.' },
        ].map((item) => (
          <div class="border-t border-[--color-border] pt-6" data-reveal>
            <h3 class="font-[Cormorant_Garamond] text-xl font-light mb-2">{item.title}</h3>
            <p class="text-sm text-[--color-text-muted] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Process -->
    <div class="space-y-12 mb-20 md:mb-32">
      <h2 class="text-2xl md:text-3xl font-light" data-reveal>Ablauf</h2>

      <div class="space-y-8">
        {[
          { step: '01', title: 'Anfrage', desc: 'Schreiben Sie mir über das Kontaktformular oder per E-Mail mit Ihrer Idee.' },
          { step: '02', title: 'Absprache', desc: 'Wir besprechen Details, Format, Technik und Zeitrahmen persönlich.' },
          { step: '03', title: 'Umsetzung', desc: 'Ich arbeite an Ihrem Werk und halte Sie über den Fortschritt auf dem Laufenden.' },
          { step: '04', title: 'Übergabe', desc: 'Das fertige Werk wird sicher verpackt und an Sie übergeben oder versendet.' },
        ].map((item) => (
          <div class="flex gap-6 items-start border-t border-[--color-border] pt-6" data-reveal>
            <span class="text-3xl md:text-4xl font-[Cormorant_Garamond] font-light text-[--color-accent-beige] shrink-0">
              {item.step}
            </span>
            <div>
              <h3 class="font-[Cormorant_Garamond] text-xl font-light mb-1">{item.title}</h3>
              <p class="text-sm text-[--color-text-muted] leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Pricing note -->
    <div class="border-t border-[--color-border] pt-8 mb-16" data-reveal>
      <p class="text-[--color-text-muted] leading-relaxed max-w-[55ch]">
        Es gibt keine festen Preise — jedes Werk ist einzigartig und wird
        individuell besprochen. Auftragsarbeiten für Kunden aus Lübeck, Hamburg, Schleswig-Holstein und ganz Deutschland.
        Kontaktieren Sie mich für ein unverbindliches Gespräch.
      </p>
    </div>

    <!-- CTA -->
    <div data-reveal>
      <a
        href="/contact"
        class="inline-block text-sm tracking-wide border border-[--color-text] px-8 py-4 hover:bg-[--color-text] hover:text-[--color-bg] transition-all duration-300"
      >
        Anfrage stellen
      </a>
    </div>
  </section>
</BaseLayout>
