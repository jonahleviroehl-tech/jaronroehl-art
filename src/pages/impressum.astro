---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Impressum" description="Impressum — Jaron Röhl">
  <section class="pt-32 pb-24 md:pt-40 md:pb-40 max-w-[800px] mx-auto px-6 md:px-10">
    <h1
      class="text-4xl md:text-6xl lg:text-7xl font-light tracking-tighter mb-12"
      data-reveal
    >
      Impressum
    </h1>

    <div class="space-y-8 text-[--color-text] leading-relaxed" data-reveal>
      <div>
        <h2 class="font-[Cormorant_Garamond] text-xl font-light mb-3">Angaben gemäß § 5 TMG</h2>
        <p>
          Jaron Röhl<br />
          <!-- Adresse hier einfügen -->
          [Straße und Hausnummer]<br />
          [PLZ Ort]
        </p>
      </div>

      <div>
        <h2 class="font-[Cormorant_Garamond] text-xl font-light mb-3">Kontakt</h2>
        <p>
          E-Mail: <a href="mailto:jaron.roehl@icloud.com" class="hover:opacity-60 transition-opacity duration-300">jaron.roehl@icloud.com</a>
        </p>
      </div>

      <div>
        <h2 class="font-[Cormorant_Garamond] text-xl font-light mb-3">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
        <p>
          Jaron Röhl<br />
          <!-- Adresse hier einfügen -->
          [Straße und Hausnummer]<br />
          [PLZ Ort]
        </p>
      </div>

      <div>
        <h2 class="font-[Cormorant_Garamond] text-xl font-light mb-3">Haftungsausschluss</h2>
        <h3 class="text-sm font-medium mb-2 mt-4">Haftung für Inhalte</h3>
        <p class="text-sm text-[--color-text-muted]">
          Die Inhalte dieser Seite wurden mit größter Sorgfalt erstellt.
          Für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte
          kann jedoch keine Gewähr übernommen werden.
        </p>

        <h3 class="text-sm font-medium mb-2 mt-6">Haftung für Links</h3>
        <p class="text-sm text-[--color-text-muted]">
          Diese Website enthält Links zu externen Websites Dritter, auf deren
          Inhalte kein Einfluss genommen werden kann. Für die Inhalte der
          verlinkten Seiten ist stets der jeweilige Anbieter verantwortlich.
        </p>

        <h3 class="text-sm font-medium mb-2 mt-6">Urheberrecht</h3>
        <p class="text-sm text-[--color-text-muted]">
          Alle auf dieser Website veröffentlichten Inhalte und Werke unterliegen
          dem deutschen Urheberrecht. Jede Vervielfältigung, Bearbeitung,
          Verbreitung und jede Art der Verwertung bedarf der vorherigen
          schriftlichen Zustimmung von Jaron Röhl.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
