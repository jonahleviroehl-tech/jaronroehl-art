---
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Fine Art Portfolio — Ölmalerei, Portraits, Zeichnungen', ogImage } = Astro.props;
const fullTitle = title === 'Home' ? 'Jaron Röhl — Fine Art' : `${title} — Jaron Röhl`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = ogImage ? new URL(ogImage, Astro.site).href : new URL('/images/MannvonStuhl/A6703562.JPG', Astro.site).href;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAFAF8" />
    <meta name="google-site-verification" content="tHsbic27A9L2tk8HTwiFXdCvqN2cmd80T7FZaJr-bJ0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Jaron Röhl — Fine Art" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Preload critical fonts -->
    <link rel="preload" href="https://fonts.gstatic.com/s/cormorantgaramond/v16/co3YmX5slCNuHLi8bLeY9MK7whWMhyjQEl5fsQ.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="https://cdn.fontshare.com/wf/CJTMFOYV5OWXMSDWKPAQBEFOW36BSFX5/HUPPMVYRVST7BNGTMVWQHRVYDUQFNWSH/KBBULDFBFAMYRQNLGBMHPB6SUQAYB73G.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <ClientRouter />

    <!-- hreflang -->
    <link rel="alternate" hreflang="de" href={canonicalURL.href} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL.href} />

    <!-- Page-specific head content -->
    <slot name="head" />

    <!-- Structured Data: Artist -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Jaron Röhl",
      "url": "https://jaronroehl-art.de",
      "image": socialImage,
      "jobTitle": "Bildender Künstler",
      "description": "Junger Künstler aus Lübeck — Ölmalerei, Portraits, Zeichnungen und Fotografie",
      "knowsAbout": ["Ölmalerei", "Portraitmalerei", "Zeichnung", "Fine Art", "Aquarell"],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Lübeck",
        "addressRegion": "Schleswig-Holstein",
        "addressCountry": "DE"
      },
      "email": "jaron.roehl@icloud.com",
      "sameAs": [
        "https://www.instagram.com/jari_art_/"
      ]
    })} />

    <!-- Structured Data: Art Studio / Local Business -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ArtGallery",
      "name": "Jaron Röhl — Fine Art",
      "description": "Künstleratelier in Lübeck — Ölmalerei, Portraits, Zeichnungen und Auftragsarbeiten",
      "url": "https://jaronroehl-art.de",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Lübeck",
        "addressRegion": "Schleswig-Holstein",
        "addressCountry": "DE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "53.8655",
        "longitude": "10.6866"
      },
      "areaServed": ["Lübeck", "Schleswig-Holstein", "Hamburg"],
      "founder": {
        "@type": "Person",
        "name": "Jaron Röhl"
      },
      "image": socialImage
    })} />
  </head>
  <body class="bg-[--color-bg] text-[--color-text] min-h-[100dvh]">
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function initAnimations() {
        ScrollTrigger.getAll().forEach((t) => t.kill());

        if (prefersReducedMotion) {
          document.querySelectorAll('[data-reveal]').forEach((el) => {
            (el as HTMLElement).style.opacity = '1';
            (el as HTMLElement).style.transform = 'none';
          });
          return;
        }

        // Reveal animations for [data-reveal] elements
        const reveals = document.querySelectorAll('[data-reveal]');
        if (reveals.length) {
          gsap.set(reveals, { opacity: 0, y: 30 });

          ScrollTrigger.batch(reveals, {
            onEnter: (batch) => {
              gsap.to(batch, {
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: 'power2.out',
                stagger: 0.12,
              });
            },
            start: 'top 88%',
            once: true,
          });

          // Catch elements already in viewport on load (e.g. after view transition)
          ScrollTrigger.refresh();
        }

        // Hero parallax
        const heroImg = document.querySelector('[data-parallax]');
        if (heroImg) {
          gsap.to(heroImg, {
            yPercent: 15,
            ease: 'none',
            scrollTrigger: {
              trigger: heroImg.closest('section') || heroImg,
              start: 'top top',
              end: 'bottom top',
              scrub: 0.6,
            },
          });
        }
      }

      // Safety: if any [data-reveal] is still invisible after 2s, force show
      function scheduleRevealSafety() {
        setTimeout(() => {
          document.querySelectorAll('[data-reveal]').forEach((el) => {
            if (getComputedStyle(el).opacity === '0') {
              (el as HTMLElement).style.opacity = '1';
              (el as HTMLElement).style.transform = 'none';
            }
          });
        }, 2000);
      }

      initAnimations();
      scheduleRevealSafety();
      document.addEventListener('astro:after-swap', () => {
        requestAnimationFrame(initAnimations);
        scheduleRevealSafety();
      });
    </script>
  </body>
</html>
