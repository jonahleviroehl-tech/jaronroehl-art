---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/gallery', label: 'Galerie' },
  { href: '/about', label: 'Über mich' },
  { href: '/commissions', label: 'Kommissionen' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Kontakt' },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-40 bg-[#FAFAF8] transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 py-5 flex items-center justify-between">
    <!-- Logo / Name -->
    <a href="/" class="group" data-astro-prefetch>
      <span class="font-[Cormorant_Garamond] text-xl md:text-2xl font-light tracking-tight text-[--color-text] transition-opacity duration-300 group-hover:opacity-60">
        Jaron Röhl
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          data-astro-prefetch
          class:list={[
            'text-sm tracking-wide transition-opacity duration-300 hover:opacity-60',
            currentPath === link.href ? 'opacity-100' : 'opacity-70',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://www.instagram.com/jari_art_/"
        target="_blank"
        rel="me noopener noreferrer"
        class="opacity-70 hover:opacity-100 transition-opacity duration-300"
        aria-label="Instagram"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden relative w-11 h-11 flex flex-col justify-center items-center gap-1.5"
      aria-label="Menü öffnen"
    >
      <span class="menu-line w-6 h-[2px] bg-[#2C2C2C] transition-all duration-300 origin-center"></span>
      <span class="menu-line w-6 h-[2px] bg-[#2C2C2C] transition-all duration-300 origin-center"></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay (outside nav so it's not affected by nav translateY) -->
<div id="mobile-menu" class="fixed inset-0 z-50 bg-[#FAFAF8] flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-500 md:hidden">
  <button
    id="mobile-menu-close"
    class="absolute top-5 right-6 w-11 h-11 flex items-center justify-center"
    aria-label="Menü schließen"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
  {links.map((link) => (
    <a
      href={link.href}
      data-astro-prefetch
      class="font-[Cormorant_Garamond] text-3xl font-light tracking-tight opacity-80 hover:opacity-100 transition-opacity duration-300"
    >
      {link.label}
    </a>
  ))}
  <a
    href="https://www.instagram.com/jari_art_/"
    target="_blank"
    rel="me noopener noreferrer"
    class="mt-4 opacity-60 hover:opacity-100 transition-opacity duration-300"
    aria-label="Instagram"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
    </svg>
  </a>
</div>

<script>
  function initNav() {
    const nav = document.getElementById('main-nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!nav || !menuBtn || !mobileMenu || !menuClose) return;

    // Hide/show nav on scroll
    let lastScroll = 0;
    let ticking = false;

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const currentScroll = window.scrollY;
          if (currentScroll > lastScroll && currentScroll > 100) {
            nav.style.transform = 'translateY(-100%)';
          } else {
            nav.style.transform = 'translateY(0)';
          }
          lastScroll = currentScroll;
          ticking = false;
        });
        ticking = true;
      }
    });

    // Mobile menu toggle
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    });

    const closeMenu = () => {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    };

    menuClose.addEventListener('click', closeMenu);
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
