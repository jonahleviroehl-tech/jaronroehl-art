---
const year = new Date().getFullYear();
---

<footer class="border-t border-[--color-border] mt-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 py-12 flex flex-col md:flex-row items-center justify-between gap-6">
    <p class="text-sm text-[--color-text-muted]">
      &copy; {year} Jaron Röhl
    </p>

    <div class="flex items-center gap-6">
      <a
        href="https://www.instagram.com/jari_art_/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-[--color-text-muted] hover:text-[--color-text] transition-colors duration-300 flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        Instagram
      </a>
      <a
        href="/contact"
        class="text-sm text-[--color-text-muted] hover:text-[--color-text] transition-colors duration-300"
      >
        Kontakt
      </a>
      <a
        href="/blog"
        class="text-sm text-[--color-text-muted] hover:text-[--color-text] transition-colors duration-300"
      >
        Blog
      </a>
      <a
        href="/impressum"
        class="text-sm text-[--color-text-muted] hover:text-[--color-text] transition-colors duration-300"
      >
        Impressum
      </a>
    </div>
  </div>
</footer>
